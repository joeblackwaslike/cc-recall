{
  "name": "cc-recall",
  "version": "0.1.0",
  "description": "Discoverability and enrichment for Claude Code session transcripts",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "lint": "biome ci . && eslint . --max-warnings=0",
    "lint:fix": "biome check --write . && eslint --fix .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "check": "pnpm typecheck && pnpm lint",
    "depcheck": "depcheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "depcheck": "^1.4.7",
    "eslint": "^9.28.0",
    "eslint-plugin-import-x": "^4.12.2",
    "eslint-plugin-no-secrets": "^1.1.2",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^56.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "^3.0.0"
  },
  "author": "Joe Black <joeblackwaslike@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joeblackwaslike/cc-recall.git"
  },
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "core-js", "esbuild", "unrs-resolver"]
  },
  "private": true,
  "lint-staged": {
    "*.{ts,js,json,md}": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ],
    "*.ts": ["eslint --fix --max-warnings=0 --no-warn-ignored"]
  },
  "bin": {
    "cc-recall": "./dist/bin/cc-recall.js"
  }
}
